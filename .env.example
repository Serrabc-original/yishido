# Cloudflare / Woztell
WOZTELL_ACCESS_TOKEN=
WOZTELL_OPEN_API_TOKEN=

# Claude orchestrator
ANTHROPIC_API_KEY=
CLAUDE_ORCHESTRATOR_AGENT_ID=
CLAUDE_ORCHESTRATOR_ENVIRONMENT_ID=

# OpenAI
OPENAI_API_KEY=
ROUTER_MODEL=gpt-5-nano
COPY_MODEL=gpt-5-nano
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_REASONING_EFFORT=low
VISION_MODEL=gpt-4o-mini
VISION_FALLBACK_MODEL=gpt-5-mini
AUDIO_TRANSCRIPTION_MODEL=whisper-1
MAX_AUDIO_SECONDS=180

# Buffering
BUFFER_WAIT_SECONDS=5
IMAGE_MESSAGE_WAIT_SECONDS=8
BUFFER_MAX_WAIT_SECONDS=15
AUDIO_TURN_WAIT_SECONDS=75
AUDIO_TURN_RETRY_SECONDS=3

# Orchestrator
ORCHESTRATOR_PROVIDER=openai
ORCHESTRATOR_MODEL=gpt-5.4-mini
ORCHESTRATOR_FALLBACK_PROVIDER=claude

# Storage / integrations
R2_PUBLIC_BASE_URL=
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_SECRET=

# Core observability / optional memory
DEBUG_LOGS=false
SAVE_CONVERSATION_LOGS=false
ENABLE_USER_STYLE_PROFILE=false
ENABLE_CUSTOMER_MEMORY=false
ENABLE_REMINDERS=false
ENABLE_LISTS=false
ENABLE_WHATSAPP_INTERACTIVE=false
ENABLE_TEMPLATE_MODULE=false
